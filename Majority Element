class Solution {
    public int majorityElement(int[] nums) {
        int major = 0;
        int count = 0;

        for (int i = 0; i < nums.length; i++) {
            int num = nums[i];

            if (count == 0) {
                major = num;
            }

            if (num == major) {
                count++;
            } else {
                count--;
            }
        }

        return major;
    }
}
