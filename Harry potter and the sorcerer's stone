import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        
        Scanner sc = new Scanner(System.in);

        int n = Math.abs(sc.nextInt());

        int lastDigit = n % 10;
        int firstDigit = n / 1000;

        System.out.println(firstDigit + lastDigit);
    }
}
